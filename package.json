{
  "name": "sms-budget-app",
  "version": "1.0.0",
  "description": "SMS Budget Planner - Ionic + Angular + Firebase",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4201",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "android": "ionic capacitor build android",
    "android:run": "ionic capacitor run android -l --external",
    "android:open": "ionic capacitor open android",
    "pwa:serve": "npx http-server ./dist/sms-budget-app -p 8080",
    "capacitor": "npm run build && npx cap sync android && npx cap open android"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^17.3.0",
    "@angular/core": "^17.3.0",
    "@angular/fire": "^17.0.1",
    "@angular/forms": "^17.3.0",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-browser-dynamic": "^17.3.0",
    "@angular/router": "^17.3.0",
    "@angular/service-worker": "^17.3.0",
    "@capacitor/android": "6.2.1",
    "@capacitor/app": "6.0.3",
    "@capacitor/core": "6.2.1",
    "@capacitor/haptics": "6.0.3",
    "@capacitor/keyboard": "6.0.4",
    "@capacitor/preferences": "6.0.4",
    "@capacitor/status-bar": "6.0.3",
    "@ionic/angular": "^7.8.0",
    "@ionic/angular-toolkit": "^11.0.1",
    "@solimanware/capacitor-sms-reader": "^5.0.3",
    "apexcharts": "^3.49.0",
    "date-fns": "^3.6.0",
    "firebase": "^10.11.0",
    "rxjs": "~7.8.1",
    "tslib": "^2.6.2",
    "zone.js": "~0.14.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.0",
    "@angular/cli": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/compiler-cli": "^17.3.0",
    "@capacitor/cli": "6.2.1",
    "@ionic/cli": "^7.2.0",
    "@types/jasmine": "~5.1.4",
    "jasmine-core": "~5.1.2",
    "karma": "~6.4.3",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.4.4"
  }
}